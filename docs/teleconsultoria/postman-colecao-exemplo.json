{
  "info": {
    "name": "Teleconsultoria",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleção de exemplo com variáveis de ambiente para testar APIs internas/externas sem dados sensíveis."
  },
  "item": [
    {
      "name": "Ping BaseURL",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/status",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "status"
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    { "key": "base_url", "value": "(api)" },
    { "key": "auth_token", "value": "" }
  ]
}
